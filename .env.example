# Database Configuration (Amazon RDS PostgreSQL)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_secure_password
DB_NAME=sara_db

# Google Gemini API
GEMINI_API_KEY=

# Embedding and LLM Configuration
EMBEDDING_MODEL="sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
EMBEDDING_DIM=768
LLM_MODEL="gemini-pro"
MAX_TOKENS=2048
TOP_K_FRAGMENTS=3
SIMILARITY_THRESHOLD=0.65

# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
API_TITLE=SARA - Sistema de Asistencia de Reglamentos Académicos
API_VERSION=1.0.0

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# AWS / S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=
S3_BUCKET_NAME=your-s3-bucket-name
S3_PREFIX=documents/

# Auth / JWT Configuration
JWT_SECRET_KEY=change-this-secret-key-to-a-long-random-32-plus-char-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
